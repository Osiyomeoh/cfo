{
  "name": "personal-cfo-agent",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:clean": "npm run clean && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "compile": "TS_NODE_PROJECT=tsconfig.hardhat.json hardhat compile",
    "compile:clean": "npm run clean:hardhat && npm run compile",
    "clean": "rm -rf .next cache artifacts typechain-types",
    "clean:hardhat": "TS_NODE_PROJECT=tsconfig.hardhat.json hardhat clean",
    "clean:all": "npm run clean && npm run clean:hardhat",
    "test:contracts": "TS_NODE_PROJECT=tsconfig.hardhat.json hardhat test",
    "deploy:registry": "TS_NODE_PROJECT=tsconfig.hardhat.json hardhat run scripts/deploy-registry.ts --network mantleSepolia",
    "deploy:registry:mainnet": "TS_NODE_PROJECT=tsconfig.hardhat.json hardhat run scripts/deploy-registry.ts --network mantle"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "ethers": "^6.16.0",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.8",
    "@nomicfoundation/hardhat-ethers": "^3.0.8",
    "@nomicfoundation/hardhat-verify": "^2.0.12",
    "@openzeppelin/contracts": "^5.2.0",
    "@tailwindcss/postcss": "^4",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "chai": "^4.5.0",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "hardhat": "^2.22.18",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
}
